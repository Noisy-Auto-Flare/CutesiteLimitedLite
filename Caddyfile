{
    # Global options
    email admin@example.com
}

# Proxy all requests to frontend
# Proxy /api to backend
# Proxy /uploads to backend

:80 {
    request_body {
        max_size 10GB
    }
    reverse_proxy /api/* backend:8000
    reverse_proxy /uploads/* backend:8000
    reverse_proxy * frontend:3000
}
